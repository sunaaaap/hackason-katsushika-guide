{
  "platform": {
    "apiRuntime": "python:3.11"
  },
  "routes": [
    {
      "route": "/api/*",
      "allowedRoles": ["reviewer"]
    },
    {
      "route": "/*",
      "allowedRoles": ["reviewer"]
    }
  ],
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/aad?post_login_redirect_uri=/",
      "statusCode": 302
    },
    "403": {
      "rewrite": "/index.html",
      "statusCode": 403
    }
  }
}
